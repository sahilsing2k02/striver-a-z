int missingNumber(vector<int>& nums) {
    int n = nums.size();
    int total = n * (n + 1) / 2;
    
    int sum = 0;
    for(int num : nums) sum += num;

    return total - sum;
}

optimal:
int missingNumber(vector<int>& nums) {
    int xor1 = 0, xor2 = 0;
    int n = nums.size();

    for(int i = 0; i < n; i++){
        xor1 ^= i;
        xor2 ^= nums[i];
    }

    return xor1 ^ xor2 ^ n;
}
